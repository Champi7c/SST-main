# Clé secrète Django (générer une nouvelle en production)
SECRET_KEY=django-insecure-change-me-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# CORS (prod) : origines autorisées, séparées par des virgules (ex. frontend Cloudflare Pages)
# CORS_ALLOWED_ORIGINS=https://votre-projet.pages.dev,https://votre-domaine.com

# MySQL – base sst, port 3308 (phpMyAdmin)
# Si DB_NAME est défini, Django utilise MySQL ; sinon SQLite.
DB_NAME=sst
DB_HOST=127.0.0.1
DB_PORT=3308
DB_USER=root
DB_PASSWORD=
