# =============================================================================
# VARIABLES D'ENVIRONNEMENT - PRODUCTION (Railway)
# =============================================================================
# IMPORTANT: NE PAS COMMITTER CE FICHIER!
# Copier ce fichier vers .env et configurer les valeurs

# -----------------------------------------------------------------------------
# SÉCURITÉ
# -----------------------------------------------------------------------------
# Générer une clé secrète robuste: python -c "import secrets; print(secrets.token_urlsafe(50))"
SECRET_KEY=your-secret-key-here-generate-with-secrets.token_urlsafe(50)

# -----------------------------------------------------------------------------
# DEBUG (False en production)
# -----------------------------------------------------------------------------
DEBUG=False

# -----------------------------------------------------------------------------
# HÔTES AUTORISÉS
# -----------------------------------------------------------------------------
# URL de votre frontend Netlify (sans slash final)
ALLOWED_HOSTS=sst-backend.up.railway.app,your-frontend.netlify.app

# -----------------------------------------------------------------------------
# BASE DE DONNÉES - MySQL sur Railway
# -----------------------------------------------------------------------------
# Railway fournit DATABASE_URL automatiquement (format: mysql://user:pass@host:port/dbname)
# Pas besoin de configurer DB_* individuellement si DATABASE_URL est présent
# DATABASE_URL=mysql://user:password@host:port/database

# Configuration alternative (si pas de DATABASE_URL):
# DB_NAME=sst_platform
# DB_HOST=mysql.railway.internal
# DB_PORT=3306
# DB_USER=root
# DB_PASSWORD=your-password

# -----------------------------------------------------------------------------
# CORS - Origines autorisées
# -----------------------------------------------------------------------------
# URLs du frontend (Netlify) séparées par des virgules
CORS_ALLOWED_ORIGINS=https://your-frontend.netlify.app,http://localhost:3000

# -----------------------------------------------------------------------------
# NETLIFY (optionnel - pour les redirections)
# -----------------------------------------------------------------------------
NETLIFY_URL=https://your-frontend.netlify.app

# -----------------------------------------------------------------------------
# PARAMÈTRES SSL (production)
# -----------------------------------------------------------------------------
SECURE_SSL_REDIRECT=True
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True

